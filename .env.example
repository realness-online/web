# Admin phone number with country code (e.g., US +1)
VITE_ADMIN_ID=+12345678900

# Firebase API key (found in Firebase Console)
VITE_API_KEY=your_firebase_api_key_here

# Firebase auth domain (usually your-project-id.firebaseapp.com)
VITE_AUTH_DOMAIN=your-project-name.firebaseapp.com

# Firebase app ID (found in Firebase Console)
VITE_APP_ID=1:123456789012:web:abcd1234efgh5678

# Firebase project ID (the name you gave your Firebase project)
VITE_PROJECT_ID=your-project-name

# Firebase storage bucket (usually your-project-id.appspot.com)
VITE_STORAGE_BUCKET=your-project-name.appspot.com

# Firebase messaging sender ID (found in Firebase Console)
VITE_MESSAGING_SENDER_ID=123456789012

# Stripe Buy Button for voluntary sponsorship.
# Create the button in the Stripe dashboard with a custom amount and
# a success URL of:
#   https://your-host/account?sponsor=ok&session_id={CHECKOUT_SESSION_ID}
# The publishable key is safe to ship to the browser. Use pk_test_... in
# development and pk_live_... in production. Leave both unset to hide the
# Sponsor button.
VITE_STRIPE_BUY_BUTTON_ID=buy_btn_your_id_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
