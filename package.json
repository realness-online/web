{
  "name": "@realness.online/web",
  "version": "2.2.8",
  "private": false,
  "type": "module",
  "keywords": [
    "svg",
    "computer-graphics",
    "vector-graphics",
    "Private",
    "Realtime Graphics",
    "animation",
    "Social Network",
    "potrace",
    "trace",
    "tracing",
    "posterization"
  ],
  "description": "When people search for 'outsider social network' they'll find realness online. The medium is the message",
  "author": "Scott Fryxell <sfryxell@gmail.com>",
  "scripts": {
    "dev": "vite",
    "certs": "./generate-certs.sh",
    "dev:workers": "rollup -c workers.config.js --watch",
    "build": "npm run build:icons && npm run build:wasm && vite build",
    "build:icons": "node scripts/generate-icons.js",
    "build:workers": "rollup -c workers.config.js",
    "build:wasm": "wasm-pack build tracer --target web --out-dir ../artifacts/wasm",
    "serve": "vite preview",
    "serve:https": "serve dist",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "deploy": "npm run build:wasm && npm run build:workers && npm run build && firebase deploy --only hosting,storage -m $npm_package_version",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "release": "npm run release:gh && npm run release:npm && git tag v$npm_package_version",
    "release:npm": "npm publish",
    "release:gh": "gh release create $npm_package_version",
    "prepare": "husky",
    "docs": "jsdoc -c jsdoc.json",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:fail-fast": "vitest run --bail=1",
    "test:keymaps": "node test-keymap-build.js",
    "fallow": "fallow",
    "fallow:fix": "fallow fix",
    "type": "tsc --pretty",
    "pre-commit": "npm run format && npm run lint:check && npm run type && npm run test",
    "storage:compress": "node scripts/compress-files.js",
    "storage:upload": "node scripts/upload-files.js",
    "storage:download": "node scripts/download-files.js",
    "server:start": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"./loader.mjs\", pathToFileURL(\"./\"));' scripts/server.js",
    "server:sync": "node scripts/sync.js"
  },
  "dependencies": {
    "@vueuse/core": "14.2.1",
    "ag-psd": "^30.1.0",
    "country-code-emoji": "2.3.0",
    "dompurify": "^3.3.3",
    "exifreader": "4.38.1",
    "firebase": "12.12.0",
    "idb-keyval": "6.2.2",
    "libphonenumber-js": "1.12.41",
    "linkedom": "0.18.12",
    "marked": "18.0.0",
    "marked-gfm-heading-id": "4.1.4",
    "mediabunny": "1.40.1",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@testing-library/jest-dom": "6.9.1",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "1.6.15",
    "@vitest/ui": "4.1.4",
    "@vue/test-utils": "2.4.6",
    "canvas": "3.2.3",
    "eslint": "10.2.0",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-vue": "10.8.0",
    "fake-indexeddb": "6.2.5",
    "fallow": "^2.28.2",
    "globals": "17.4.0",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "jsdoc": "4.0.5",
    "pako": "2.1.0",
    "prettier": "3.8.2",
    "rollup": "4.60.1",
    "rollup-plugin-analyzer": "4.0.0",
    "rollup-plugin-copy": "3.5.0",
    "stylus": "0.64.0",
    "svgo": "4.0.1",
    "typescript": "5.8.3",
    "vite": "7.3.2",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-wasm": "3.6.0",
    "vitest": "4.1.4"
  },
  "browserslist": [
    ">0.5%",
    "not dead",
    "not IE 11",
    "not IE_Mob 11",
    "not op_mini all",
    "not ios_saf < 16"
  ],
  "license": "UNLICENSED"
}
