{
  "name": "@realness.online/web",
  "version": "1.4.51",
  "private": false,
  "type": "module",
  "description": "When people search for 'outsider social network' they'll find realness online",
  "author": "Scott Fryxell <sfryxell@me.com>",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "serve:https": "serve dist",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix",
    "deploy": "yarn lint && yarn format && yarn workers && yarn build && firebase deploy --only hosting,storage -m $npm_package_version",
    "format": "prettier .  --write",
    "format:check": "prettier . --check",
    "release": "yarn release:gh && yarn release:npm && git tag v$npm_package_version",
    "release:npm": "yarn publish",
    "release:gh": "gh release create $npm_package_version",
    "workers": "webpack --config workers.config.cjs",
    "workers:dev": "yarn workers --mode=development --watch",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
  "dependencies": {
    "@davidmarkclements/hsl-to-hex": "1.0.2",
    "@ffmpeg/core": "^0.11.0",
    "@ffmpeg/ffmpeg": "^0.11.6",
    "@headlessui/vue": "^1.5.0",
    "@heroicons/vue": "^2.0.17",
    "@mediapipe/selfie_segmentation": "^0.1.1632777926",
    "@realness.online/potrace": "../potrace/",
    "@tensorflow-models/body-segmentation": "^1.0.1",
    "@tensorflow-models/coco-ssd": "^2.2.2",
    "@tensorflow-models/depth-estimation": "^0.0.3",
    "@tensorflow/tfjs-backend-cpu": "4.2.0",
    "@tensorflow/tfjs-backend-wasm": "4.2.0",
    "@tensorflow/tfjs-backend-webgl": "4.2.0",
    "@tensorflow/tfjs-converter": "4.2.0",
    "@tensorflow/tfjs-core": "4.2.0",
    "@vueuse/core": "9.13.0",
    "firebase": "9.19.0",
    "hsl-to-hex": "1.0.0",
    "idb-keyval": "6.2.0",
    "jimp": "0.22.7",
    "libphonenumber-js": "1.10.24",
    "node-vibrant": "3.2.1-alpha.1",
    "object-hash": "3.0.0",
    "pako": "^2.0.4",
    "rgb-hex": "4.0.1",
    "svgo": "3.0.2",
    "vue": "3.2.47",
    "vue-router": "4.1.6",
    "workbox-build": "^6.5.4",
    "workbox-window": "^6.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "4.1.0",
    "@vue/test-utils": "2.3.2",
    "assert": "2.0.0",
    "browserify-fs": "1.0.0",
    "browserify-zlib": "0.2.0",
    "buffer-browserify": "0.2.5",
    "c8": "7.13.0",
    "eslint": "8.37.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-vue": "9.10.0",
    "fake-indexeddb": "4.0.1",
    "firebase-tools": "11.25.2",
    "happy-dom": "8.9.0",
    "https-browserify": "1.0.0",
    "https-localhost": "^4.7.1",
    "husky": "^8.0.1",
    "mockdate": "3.0.5",
    "os-browserify": "0.3.0",
    "path-browserify": "1.0.1",
    "pinst": "^3.0.0",
    "prettier": "2.8.7",
    "process": "0.11.10",
    "simplex-noise": "4.0.1",
    "stream-browserify": "3.0.0",
    "stream-http": "3.2.0",
    "stylus": "0.59.0",
    "util": "0.12.5",
    "vite": "4.2.1",
    "vite-plugin-package-version": "1.0.2",
    "vite-plugin-pwa": "0.14.7",
    "vitest": "0.29.8",
    "webpack": "5.77.0",
    "webpack-cli": "5.0.1"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "es2021": true,
      "jest": true,
      "serviceworker": true,
      "worker": true
    },
    "globals": {
      "defineProps": "readonly",
      "defineEmits": "readonly",
      "defineExpose": "readonly",
      "withDefaults": "readonly"
    },
    "extends": [
      "eslint:recommended",
      "plugin:vue/vue3-recommended",
      "prettier"
    ],
    "rules": {
      "no-import-assign": "off",
      "camelcase": 0,
      "indent": "off",
      "lines-between-class-members": 0,
      "vue/multi-word-component-names": "off",
      "vue/require-default-prop": "off",
      "vue/prop-name-casing": [
        "error",
        "snake_case"
      ],
      "vue/singleline-html-element-content-newline": "off",
      "vue/html-closing-bracket-spacing": [
        "error",
        {
          "selfClosingTag": "always"
        }
      ],
      "vue/html-closing-bracket-newline": [
        "error",
        {
          "singleline": "never",
          "multiline": "never"
        }
      ]
    }
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "bracketSameLine": true,
    "arrowParens": "avoid",
    "vueIndentScriptAndStyle": true
  },
  "browserslist": [
    "last 2 versions"
  ],
  "license": "UNLICENSED"
}
