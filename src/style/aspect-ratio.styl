// Poster slice + storytelling layout — html[data-aspect-ratio] from App.vue
// Surface tokens follow prefers-color-scheme via color.styl. No inline --custom-prop writes.

html
  --storytelling-slide-width 100dvw

html[data-aspect-ratio="1/1"]
  @media (min-aspect-ratio: 1/1)
    --storytelling-slide-width 100dvh

poster-slice-ratios = {
  '1/1': 1 / 1,
  '1.618/1': 1.618 / 1,
  '16/9': 16 / 9,
  '2.35/1': 2.35 / 1,
  '2.76/1': 2.76 / 1
}

for mode, ratio in poster-slice-ratios
  html[data-aspect-ratio="{mode}"] svg[itemtype='/posters'][data-aspect]
    aspect-ratio ratio
