@require 'mixins'

base-line = 1.333rem

min-modular = 1.250
max-modular = 1.414

min-font = 1.125rem
max-font = 1.33rem

pad-begins = round(base-line * 26)
typing-begins = round(base-line * 48)
display-begins = round(base-line * 60)

page-width = round(base-line * 22)

page-width-large = round(base-line * 32)

poster-min-width = round(base-line * 10, 0)

poster-grid-height = round(base-line * 22, 0)

poster-thoughts-height = round((page-width), 2)

accent            = unquote('var(--accent)')
working           = unquote('var(--working)')
emphasis          = unquote('var(--emphasis)')
warning           = unquote('var(--warning)')

:root {
  interpolate-size: allow-keywords;
  accent-color: var(--emphasis);

  --graphite: hsl(0, 0%, 32%);
  --black-dark: hsla(300, 1%, 2%, 0.99);
  --basalt: hsla(57, 8%, 16%, 1);
  --basalt-transparent: hsla(57, 8%, 16%, 0.50);
  --white: hsla(57, 13%, 88%, 0.9);
  --white-text: hsla(57, 13%, 82%, 0.95);
  --chalk: hsl(57, 16%, 91%);
  --surface-glass-light: hsla(57, 13%, 88%, 0.85);

  --moonlight: hsla(30, 20%, 8%, 1);
  --pumice: hsl(57, 8%, 21.25%);
  --bone: hsl(57, 13%, 83.5%);

  --water-lighten: hsla(180, 40%, 62%, 1);
  --water-fill: hsla(180, 30%, 45%, 1);
  --water-darken: hsla(180, 60%, 28%, 1);

  --clay-lighten: hsla(0, 40%, 64%, 1);
  --clay-fill: hsla(0, 30%, 45%, 1);
  --clay-darken: hsla(0, 35%, 38%, 1);

  --moss-lighten: hsla(120, 35%, 60%, 1);
  --moss-fill: hsla(120, 30%, 43%, 1);
  --moss-darken: hsla(120, 35%, 30%, 1);

  --slate-lighten: hsla(215, 35%, 65%, 1);
  --slate-fill: hsla(215, 25%, 47%, 1);
  --slate-darken: hsla(215, 30%, 38%, 1);

  // role tokens (--accent, --emphasis, ...) live in color.styl only
  // (lazy chunks re-import variables)
  --ochre-lighten: hsla(37, 91%, 70%, 0.75);
  --ochre: hsla(37, 91%, 54%, 0.75);
  --ochre-darken: hsla(37, 91%, 38%, 0.75);

  --sediment-lighten: hsla(25, 45%, 78.5%, 1);
  --sediment: hsla(25, 45%, 62.5%, 1);
  --sediment-darken: hsla(25, 45%, 46.5%, 1);

  --sand-lighten: hsla(26, 40%, 61%, 1);
  --sand: hsla(26, 40%, 45%, 1);
  --sand-darken: hsla(26, 40%, 29%, 1);

  --gravel-lighten: hsla(26, 30%, 54%, 1);
  --gravel: hsla(26, 30%, 38%, 1);
  --gravel-darken: hsla(26, 30%, 22%, 1);

  --rocks-lighten: hsla(33, 28%, 47%, 1);
  --rocks: hsla(33, 28%, 31%, 1);
  --rocks-darken: hsla(33, 28%, 15%, 1);

  --boulders-lighten: hsla(0, 25%, 47%, 1);
  --boulders: hsla(0, 25%, 31%, 1);
  --boulders-darken: hsla(0, 25%, 15%, 1);

  --base-line: base-line;
  --min-modular: min-modular;
  --max-modular: max-modular;
  --min-font: min-font;
  --max-font: max-font;

  --pad-begins: pad-begins;
  --typing-begins: typing-begins;
  --display-begins: display-begins;
  --page-width: page-width;
  --page-width-large: page-width-large;
  --poster-min-width: poster-min-width;
  --poster-grid-height: poster-grid-height;
  --poster-thoughts-height: poster-thoughts-height;
}
