@require 'mixins'


// Materials — paint on the shelf. Named for character, not wavelength.
// Recipe: light ~35% / 32-40% S/L, dark lifted to 60-66%, mid fill for solids.
// https://nice-converter.com/color/hsla-to-rgba

// surfaces
graphite          = hsl(0, 0%, 32%)
black-dark        = hsla(300,  1%, 2%, 0.99)
atmosphere        = hsla(36, 22%, 4.5%, 1) // #0e0c09
basalt            = hsla(57, 8%, 16%, 1) // #2c2c26
basalt-transparent = hsla(57, 8%, 16%, 0.50) // #2c2c26
pumice            = hsl(57, 8%, 21.25%) // dark poster — same offset off basalt as bone is off chalk

white             = hsla( 57, 13%, 88%, 0.9)
white-text        = hsla( 57, 13%, 82%, 0.95)
chalk             = hsl( 57, 16%, 91%)
bone              = hsl( 57, 13%, 83.5%)

// accent pair — water is the cool primary, clay the warm half
water-fill        = hsla(180, 30%, 45%, 1)
clay-fill         = hsla(0, 30%, 45%, 1)
water-light       = hsla(180, 35%, 32%, 1)
clay-light        = hsla(0, 35%, 38%, 1)
water-dark        = hsla(180, 40%, 62%, 1)
clay-dark         = hsla(0, 40%, 64%, 1) // 64% clears 4.5 AA on basalt; 62% measured 4.22
surface-glass-light    = hsla(57, 13%, 88%, 0.85)

// in stock — on the shelf, unassigned
moss-light        = hsla(120, 35%, 30%, 1)
moss-dark         = hsla(120, 35%, 60%, 1)
moss-fill         = hsla(120, 30%, 43%, 1)
slate-light       = hsla(215, 30%, 38%, 1)
slate-dark        = hsla(215, 35%, 65%, 1)
slate-fill        = hsla(215, 25%, 47%, 1)
heather-light     = hsla(285, 25%, 40%, 1)
heather-dark      = hsla(285, 30%, 66%, 1)
heather-fill      = hsla(285, 22%, 49%, 1)

// signals — interrupt rather than decorate; same in both schemes
sulfur            = hsla(55, 94%, 40%, 0.75)
ochre             = hsla(37, 91%, 54%, 0.75)

sediment          = hsla(25, 45%, 62.5%, 1)
sand              = hsla(45, 40%, 45%, 1)
gravel            = hsla(38, 18%, 43%, 1)
rocks             = hsla(30, 15%, 35.5%, 1)
boulders          = hsla(0, 25%, 31%, 1)

// roles — the layer components touch; UI uses roles, the canvas uses paint
accent            = unquote('var(--accent)')
emphasis          = unquote('var(--emphasis)')
danger            = unquote('var(--danger)')
warning           = unquote('var(--warning)')
caution           = unquote('var(--caution)')
success           = unquote('var(--success)')

base-line = 1.333rem // smallest horizontal block of content

// Modular scale. for small and larger screens
// if you change the scales you'll need to recalculate when the are applied
// so that the typography scales smoothly http://type-scale.com/
min-modular = 1.250
max-modular = 1.414

min-font = 1.125rem
max-font = 1.33rem

// Media queries defining device types
pad-begins = round(base-line * 26)
typing-begins = round(base-line * 48)
display-begins = round(base-line * 60)

page-width = round(base-line * 22)

page-width-large = round(base-line * 32)

poster-min-width = round(base-line * 10, 0)

poster-grid-height = round(base-line * 22, 0)

poster-thoughts-height = round((page-width), 2)




:root {
  interpolate-size: allow-keywords;
  accent-color: var(--emphasis);

  // Materials
  --graphite: graphite;
  --black-dark: black-dark;
  --atmosphere: atmosphere;
  --basalt: basalt;
  --basalt-transparent: basalt-transparent;
  --pumice: pumice;

  --white: white;
  --white-text: white-text;
  --chalk: chalk;
  --bone: bone;

  --water-fill: water-fill;
  --clay-fill: clay-fill;
  --water-light: water-light;
  --water-dark: water-dark;
  --clay-light: clay-light;
  --clay-dark: clay-dark;
  --moss-light: moss-light;
  --moss-dark: moss-dark;
  --moss-fill: moss-fill;
  --slate-light: slate-light;
  --slate-dark: slate-dark;
  --slate-fill: slate-fill;
  --heather-light: heather-light;
  --heather-dark: heather-dark;
  --heather-fill: heather-fill;
  // role tokens (--accent, --emphasis, ...) live in color.styl only
  // (lazy chunks re-import variables)
  --sulfur: sulfur;
  --ochre: ochre;
  --sediment: sediment;
  --sand: sand;
  --gravel: gravel;
  --rocks: rocks;
  --boulders: boulders;

  // Typography
  --base-line: base-line;
  --min-modular: min-modular;
  --max-modular: max-modular;
  --min-font: min-font;
  --max-font: max-font;

  // Layout
  --pad-begins: pad-begins;
  --typing-begins: typing-begins;
  --display-begins: display-begins;
  --page-width: page-width;
  --page-width-large: page-width-large;
  --poster-min-width: poster-min-width;
  --poster-grid-height: poster-grid-height;
  --poster-thoughts-height: poster-thoughts-height;
}
