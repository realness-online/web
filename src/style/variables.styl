@require 'mixins'

base-line = 1.333rem

min-modular = 1.250
max-modular = 1.414

min-font = 1.125rem
max-font = 1.33rem

pad-begins = round(base-line * 26)
typing-begins = round(base-line * 48)
display-begins = round(base-line * 60)

page-width = round(base-line * 22)

page-width-large = round(base-line * 32)

poster-min-width = round(base-line * 10, 0)

poster-grid-height = round(base-line * 22, 0)

poster-thoughts-height = round((page-width), 2)

accent            = unquote('var(--accent)')
working           = unquote('var(--working)')
emphasis          = unquote('var(--emphasis)')
warning           = unquote('var(--warning)')

:root {
  interpolate-size: allow-keywords;
  accent-color: var(--emphasis);

  --graphite: unquote('oklch(0.4386 0 89.88)');
  --black-dark: unquote('oklch(0.1149 0 89.88 / 0.99)');
  --basalt: unquote('oklch(0.291 0.0106 107.04)');
  --basalt-transparent: unquote('oklch(0.291 0.0106 107.04 / 0.5)');
  --white: unquote('oklch(0.9166 0.0107 106.61 / 0.9)');
  --white-text: unquote('oklch(0.8738 0.0149 102.49 / 0.95)');
  --chalk: unquote('oklch(0.9389 0.0094 99.99)');
  --surface-glass-light: unquote('oklch(0.9166 0.0107 106.61 / 0.85)');

  --moonlight: unquote('oklch(0.1946 0.0102 67.17)');
  --pumice: unquote('oklch(0.3468 0.0136 101.23)');
  --bone: unquote('oklch(0.8853 0.0148 106.7)');

  --water-lighten: unquote('oklch(0.7733 0.0771 195.67)');
  --water-fill: unquote('oklch(0.6249 0.0699 195.51)');
  --water-darken: unquote('oklch(0.5041 0.0773 194.98)');

  --clay-lighten: unquote('oklch(0.6707 0.0924 19.78)');
  --clay-fill: unquote('oklch(0.5138 0.0925 20.77)');
  --clay-darken: unquote('oklch(0.455 0.0939 21.45)');

  --moss-lighten: unquote('oklch(0.7327 0.1251 144.17)');
  --moss-fill: unquote('oklch(0.5894 0.1189 143.88)');
  --moss-darken: unquote('oklch(0.4633 0.1003 143.75)');

  --slate-lighten: unquote('oklch(0.7021 0.0606 256.58)');
  --slate-fill: unquote('oklch(0.5498 0.0624 256.85)');
  --slate-darken: unquote('oklch(0.4701 0.0627 257.12)');

  // role tokens (--accent, --emphasis, ...) live in color.styl only
  // (lazy chunks re-import variables)
  --ochre-lighten: unquote('oklch(0.8473 0.1203 78.08 / 0.75)');
  --ochre: unquote('oklch(0.7769 0.1595 72.01 / 0.75)');
  --ochre-darken: unquote('oklch(0.6204 0.133 69.04 / 0.75)');

  --sediment-lighten: unquote('oklch(0.8397 0.0428 56.67)');
  --sediment: unquote('oklch(0.7185 0.0778 56.88)');
  --sediment-darken: unquote('oklch(0.5952 0.0995 55.43)');

  --sand-lighten: unquote('oklch(0.7072 0.0717 58.34)');
  --sand: unquote('oklch(0.5804 0.0864 57.58)');
  --sand-darken: unquote('oklch(0.4261 0.061 57.6)');

  --gravel-lighten: unquote('oklch(0.6477 0.065 58.16)');
  --gravel: unquote('oklch(0.5062 0.0571 58.17)');
  --gravel-darken: unquote('oklch(0.3499 0.0367 59.48)');

  --rocks-lighten: unquote('oklch(0.6025 0.0638 71.99)');
  --rocks: unquote('oklch(0.449 0.0452 71.36)');
  --rocks-darken: unquote('oklch(0.2807 0.0243 69.26)');

  --boulders-lighten: unquote('oklch(0.5352 0.0794 20.02)');
  --boulders: unquote('oklch(0.4003 0.0569 19.88)');
  --boulders-darken: unquote('oklch(0.2553 0.0301 19.35)');

  --base-line: base-line;
  --min-modular: min-modular;
  --max-modular: max-modular;
  --min-font: min-font;
  --max-font: max-font;

  --pad-begins: pad-begins;
  --typing-begins: typing-begins;
  --display-begins: display-begins;
  --page-width: page-width;
  --page-width-large: page-width-large;
  --poster-min-width: poster-min-width;
  --poster-grid-height: poster-grid-height;
  --poster-thoughts-height: poster-thoughts-height;
}
