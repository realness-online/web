a
  cursor: pointer
  outline: none
  color: blue
  text-decoration: none
  -webkit-tap-highlight-color: transparent
p > a
  -webkit-tap-highlight-color: transparentify(blue-fill)
  transition-property: all
  transition-duration: 0.8s
  transition-timing-function: ease-in-out
  transition-delay: 0.1s
  border-bottom: .08vmin solid blue
  border-bottom-right-radius: 0.2vmin
  border-bottom-left-radius: 0.2vmin
  &:link
    color: blue
  &:visited
    opacity: 0.82
  &:hover
    color: red
    opacity: 1
  &:active
    color: blue
