form
  width: 100%
  display: flex
  flex-direction: column
  justify-content: space-around

fieldset
  padding: round((base-line / 2 ), 2)
  overflow: hidden
  standard-border: graphite
  @media (prefers-color-scheme: dark)
    standard-border: emphasis
  legend
    color: lighten(graphite, 30%)
    &.valid
      color: accent

input
  color: emphasis
  &[type=file]
    display: none
  &:focus
    transition-property: all
    outline: 0
    &::placeholder
      color: lighten(graphite, 30%)
  &::placeholder
    color: lighten(graphite, 30%)

input
textarea
  border-color: transparent
  background-color: transparent
  &:disabled
    opacity: 1
    user-select: none
    -webkit-text-fill-color: graphite
    color: graphite

input
textarea
[contenteditable]
  user-select: text

input
textarea
button
select
  appearance: none
  -webkit-tap-highlight-color: inherit
  outline: inherit
  text-rendering: inherit
  font: inherit
  font-family: inherit
  font-size: inherit
  font-weight: inherit
  color: inherit

label
  font-weight: 300

// Toggle switch — a checkbox styled as a sliding switch. Used by preference.vue
// and as-notifications.vue. Markup: label.switch > input[switch] + span.slider
label.switch
  position: relative
  display: inline-block
  width: base-line * 3
  height: base-line * 1.5
  flex-shrink: 0
  & > input
    opacity: 0
    width: 0
    height: 0
    &:checked + .slider
      background-color: emphasis
    &:focus + .slider
      box-shadow: 0 0 1px emphasis
    &:checked + .slider:before
      transform: translateX(base-line * 1.4)
  .slider
    border-radius: base-line * 2
    position: absolute
    cursor: pointer
    top: 0
    left: 0
    right: 0
    bottom: 0
    background-color: graphite
    transition: .4s
    &:before
      border-radius: 50%
      position: absolute
      content: ""
      height: base-line * 1.2
      width: base-line * 1.2
      left: base-line * 0.2
      bottom: base-line * 0.15
      background-color: white
      opacity: 0.75
      transition: .4s

button
  standard-button: accent
  &:active
    transform: scale(0.95)
  &:focus
    outline: 0.25px solid accent
    outline-offset: base-line * 0.25
  &:disabled
    opacity: .75
    standard-button: graphite
