*,
*::before
*::after
  box-sizing: border-box
  margin:0
  padding:0
  line-height: 1.33
  -webkit-touch-callout: none
  touch-action: manipulation
  user-select: none
  -webkit-user-select: none


[outline],
[outline] *:not(svg):not(svg *)
  outline: 0.15vmin dashed graphite

[hidden]
  display: none

