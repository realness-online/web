light-accent-tokens()
  --blue blue-accent-light
  --red red-accent-light
  --surface-glass surface-glass-light

dark-accent-tokens()
  --blue blue-accent-dark
  --red red-accent-dark
  --surface-glass black-transparent

light-surface-tokens()
  --text black
  --surface white-background
  --code-surface alpha(black, 0.06)

dark-surface-tokens()
  --text white-text
  --surface var(--black-background)
  --code-surface alpha(white, 0.08)

:root
  light-accent-tokens()
  light-surface-tokens()

@media (prefers-color-scheme: dark)
  :root
    dark-accent-tokens()
    dark-surface-tokens()

html
  color: var(--text)
  background-color: var(--surface)
  color-scheme: light dark

body
  min-height: 100%
  background-color: inherit

main#realness
  background-color: inherit

section.page
  background-color: var(--surface)

.orange
  background-color: orange
  border-color: orange
  -webkit-tap-highlight-color: orange
  color: lighten(orange, 70%)
  &::placeholder
    color: lighten(orange, 90%)
.yellow
  background-color: yellow
  border-color: darken(yellow, 13%)
  color: black
  -webkit-tap-highlight-color: yellow
  @media (prefers-color-scheme: dark)
    &::placeholder
      color: black
.sediment
  background-color: sediment
  border-color: sediment
  color: lighten(sediment, 75%)
  -webkit-tap-highlight-color: sediment
  &::placeholder
    color: lighten(sediment, 75%)
  @media (prefers-color-scheme: dark)
    background-color: darken(sediment, 12%)
    color: white-text
    border-color: darken(sediment, 8%)
.red
  background-color: red-fill
  border-color: red-fill
  color: lighten(red-fill, 85%)
  -webkit-tap-highlight-color: red-fill
  &::placeholder
    color: lighten(red-fill, 85%)
  @media (prefers-color-scheme: dark)
    background-color: darken(red-fill, 8%)
    color: white-text
    border-color: darken(red-fill, 5%)
.blue
  background-color: blue-fill
  border-color: blue-fill
  color:lighten(blue-fill, 95%)
  -webkit-tap-highlight-color: blue-fill
  &::placeholder
    color: lighten(blue-fill, 95%)
  @media (prefers-color-scheme: dark)
    background-color: darken(blue-fill, 20%)
    color: white-text
    border-color: darken(blue-fill, 15%)
.black
  background-color: black
  border-color: black
  color: lighten(black, 65%)
  -webkit-tap-highlight-color: black
  &::placeholder
    color: lighten(black, 65%)
  @media (prefers-color-scheme: dark)
    background-color: darken(black, 30%)
    color: white-text
    border-color: black
