// Roles — the jobs components actually touch. Each role points at a variant;
// a rebrand is one line here, not a hundred call sites.
light-accent-tokens() {
  --accent: var(--water-darken);
  --emphasis: var(--clay-darken);
  --working: var(--moss-darken);
  --surface-glass: var(--surface-glass-light);
}

dark-accent-tokens() {
  --accent: var(--water-lighten);
  --emphasis: var(--clay-lighten);
  --working: var(--moss-lighten);
  --surface-glass: var(--basalt-transparent);
}

light-surface-tokens() {
  --text: var(--graphite);
  --surface: var(--chalk);
  --code-surface: unquote('color-mix(in srgb, var(--graphite) 6%, transparent)');
}

dark-surface-tokens() {
  --text: var(--white-text);
  --surface: var(--basalt);
  --code-surface: unquote('color-mix(in srgb, var(--white) 8%, transparent)');
}

:root {
  --warning: var(--ochre);
  light-accent-tokens();
  light-surface-tokens();
}

@media (prefers-color-scheme: dark) {
  :root {
    dark-accent-tokens();
    dark-surface-tokens();
  }
}

html {
  color: var(--text);
  background-color: var(--surface);
  color-scheme: light dark;
}

body {
  min-height: 100%;
  background-color: inherit;
}

main#realness {
  background-color: inherit;
}

section.page {
  background-color: var(--surface);
}

// Variant classes — filled controls painted with a variant directly.
// The blessed exception to "components touch roles": used where a control
// should read as a variant (install CTA, compose box), not a semantic state.
.water {
  background-color: var(--water-fill);
  border-color: var(--water-fill);
  color: unquote('color-mix(in srgb, var(--water-fill) 5%, white)');
  -webkit-tap-highlight-color: var(--water-fill);
  &::placeholder {
    color: unquote('color-mix(in srgb, var(--water-fill) 5%, white)');
  }
  @media (prefers-color-scheme: dark) {
    background-color: unquote('color-mix(in srgb, var(--water-fill) 80%, black)');
    color: var(--white-text);
    border-color: unquote('color-mix(in srgb, var(--water-fill) 85%, black)');
  }
}
.graphite {
  background-color: var(--graphite);
  border-color: var(--graphite);
  color: unquote('color-mix(in srgb, var(--graphite) 35%, white)');
  -webkit-tap-highlight-color: var(--graphite);
  &::placeholder {
    color: unquote('color-mix(in srgb, var(--graphite) 35%, white)');
  }
  @media (prefers-color-scheme: dark) {
    background-color: unquote('color-mix(in srgb, var(--graphite) 70%, black)');
    color: var(--white-text);
    border-color: var(--graphite);
  }
}
