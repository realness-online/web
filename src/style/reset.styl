// The actual CSS output built on base-line.styl's constants: the reset that
// zeroes default spacing (a precondition for vertical rhythm to mean
// anything), the root custom properties, and the fluid modular type scale.
// Loaded exactly once, via style/index.styl - never @require this from a
// component's own <style lang="stylus"> block, or its rules get emitted
// again into that component's chunk (see vite.config.js's
// css.preprocessorOptions.stylus.imports for the shared constants instead).
//
// implementation from:
//   https://www.smashingmagazine.com/2016/05/fluid-typography/

@require 'base-line'

// Color tokens (oklch) live in palette.css - plain CSS, no unquote noise.
// Everything else is a single source of truth for the custom properties
// this file establishes: core numeric constants plus the modular-scale
// bounds clamp() reads for its min/max args (the fluid-calc() middle
// argument still needs the Stylus-side $vars, since it strips units at
// compile time).
:root {
  interpolate-size: allow-keywords;

  --base-line: base-line;
  --min-modular: min-modular;
  --max-modular: max-modular;
  --min-font: min-font;
  --max-font: max-font;

  --pad-begins: pad-begins;
  --typing-begins: typing-begins;
  --display-begins: display-begins;
  --page-width: page-width;
  --page-width-large: page-width-large;
  --page-width-max: page-width-max;
  --support-page-width: support-page-width;
  --poster-min-width: poster-min-width;
  --poster-grid-height: poster-grid-height;
  --poster-thoughts-height: poster-thoughts-height;

  --h1-min: $h1-min;
  --h1-max: $h1-max;
  --h2-min: $h2-min;
  --h2-max: $h2-max;
  --h3-min: $h3-min;
  --h3-max: $h3-max;
  --h4-min: $h4-min;
  --h4-max: $h4-max;
  --h5-min: $h5-min;
  --h5-max: $h5-max;
  --h6-min: $h6-min;
  --h6-max: $h6-max;
}

// ***************** reset ******************************************
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  line-height: 1.33;
  -webkit-touch-callout: none;
  touch-action: manipulation;
  user-select: none;
  -webkit-user-select: none;
}

[outline],
[outline] *:not(svg):not(svg *) {
  outline: 0.15vmin dashed var(--graphite);
}

[hidden] {
  display: none;
}

// ***************** fluid-typography *****************************************
html {
  font-family: 'Lato', -apple-system, system-ui;
  font-size: clamp(var(--min-font), fluid-calc(), var(--max-font));
  text-rendering: optimizeLegibility;
  @media (prefers-color-scheme: dark) {
    color: var(--bone);
    font-smoothing: antialiased; //https://usabilitypost.com/2012/11/05/stop-fixing-font-smoothing/
  }
}
p, textarea:focus, input, blockquote, form {
  max-width: var(--page-width);
}

h1 {
  font-size: clamp(var(--h1-min), fluid-calc($h1-min, $h1-max), var(--h1-max));
}
h2 {
  font-size: clamp(var(--h2-min), fluid-calc($h2-min, $h2-max), var(--h2-max));
}
h3, address > b {
  font-size: clamp(var(--h3-min), fluid-calc($h3-min, $h3-max), var(--h3-max));
}
h4, span#fps {
  font-size: clamp(var(--h4-min), fluid-calc($h4-min, $h4-max), var(--h4-max));
}
h5 {
  font-size: var(--h5-min);
}
// h6 is the one step below the base unit, so dividing by the ratio makes
// $h6-min (small viewport) the numerically larger bound and $h6-max (large
// viewport) the smaller one - clamp() requires its bounds in ascending
// numeric order or it collapses to a constant, so the var() args are
// swapped here relative to every other heading (the calc() interpolation
// itself is unaffected).
h6 {
  font-size: clamp(var(--h6-max), fluid-calc($h6-min, $h6-max), var(--h6-min));
}

// ***************** vertical-rhythm ******************************************

// At least 2 baselines high
p {
  line-height: 1.33;
  margin-bottom: var(--base-line);
}
dl {
  padding: 0 var(--base-line);
}
dt {
  font-weight: 600;
  text-transform: capitalize;
}

h1,h2,h3,h4,h5,h6 {
  user-select: text;
  letter-spacing: -.02em;
  font-weight: 300;
  line-height: 1;
  margin-bottom: var(--base-line);
  // text-transform: capitalize
}
h3,h4,h5,h6 {
  letter-spacing: -.01em;
}

// Four baselines high
h1,h2,h3,h4 {
  margin-top: calc((var(--base-line) - 1em) + var(--base-line) * 2);
}

// Three baselines high
h5 {
  margin-top: calc((var(--base-line) - 1em) + var(--base-line) * 1);
}

// Two baselines high
h6 {
  margin-top: calc(var(--base-line) - 1em);
}
