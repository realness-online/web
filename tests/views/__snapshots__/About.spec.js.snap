          compact=""
        />
        <fieldset
          class="preference-stub"
          compact=""
          icon=""
        />
        <fieldset
          class="preference-stub"
          compact=""
          icon=""
          label="3D"
        />
      </menu>
    </header>
    
    <figure
      class="poster-stub"
    />
    
  </section>
  <hr />
  <section
    itemprop="preferences"
  >
    <header>
      <h2>
        Preferences
      </h2>
      <p>
         Layers, geology, motion, 3D atmosphere - every poster responds to what you turn on. Scroll the gallery above with these toggles, or reset everything and start clean. 
      </p>
      <button
        type="button"
      >
        Reset
      </button>
    </header>
    <preferences-menu-stub
      icon="true"
    />
  </section>
